# 所有文本文件自动转换换行符
* text=auto

# 指定特定文件类型的换行符
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.lock text eol=lf

# Windows 批处理文件必须用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不转换
*.png binary
*.jpg binary
*.pdf binary

